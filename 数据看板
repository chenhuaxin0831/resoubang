<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>数据看板 - 排行榜 & 词云 & 自媒体内容建议</title>
    <script src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/echarts-wordcloud@2.1.0/dist/echarts-wordcloud.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            min-height: 100vh; color: #e0e0e0; padding: 20px;
        }
        .header {
            text-align: center; padding: 30px 0 20px;
        }
        .header h1 {
            font-size: 2.2rem; background: linear-gradient(90deg, #00d2ff, #3a7bd5);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            margin-bottom: 8px;
        }
        .header p { color: #8e8ea0; font-size: 0.95rem; }
        .header-date {
            margin-top: 10px; font-size: 0.85rem; color: #666;
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .header-date .date-badge {
            background: rgba(0,210,255,0.1); color: #00d2ff; padding: 4px 12px;
            border-radius: 12px; font-weight: 500; border: 1px solid rgba(0,210,255,0.2);
        }
        .dashboard { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; max-width: 1400px; margin: 0 auto; }
        .card {
            background: rgba(255,255,255,0.05); border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.1); padding: 24px;
            backdrop-filter: blur(10px); transition: transform 0.2s;
        }
        .card:hover { transform: translateY(-2px); }
        .card-title {
            font-size: 1.1rem; font-weight: 600; margin-bottom: 16px;
            display: flex; align-items: center; gap: 8px;
        }
        .card-title .icon { font-size: 1.3rem; }
        .full-width { grid-column: 1 / -1; }

        /* 筛选控制区 */
        .filter-bar {
            max-width: 1400px; margin: 0 auto 24px; padding: 24px;
            background: rgba(255,255,255,0.05); border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px);
        }
        .filter-section { margin-bottom: 16px; }
        .filter-label {
            font-size: 0.85rem; color: #8e8ea0; margin-bottom: 10px;
            text-transform: uppercase; letter-spacing: 1px; font-weight: 500;
        }
        .platform-tabs { display: flex; flex-wrap: wrap; gap: 8px; }
        .platform-btn {
            padding: 8px 16px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.15);
            background: rgba(255,255,255,0.04); color: #ccc; font-size: 0.9rem;
            cursor: pointer; transition: all 0.2s; display: flex; align-items: center; gap: 5px;
        }
        .platform-btn:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.3); }
        .platform-btn.active {
            background: linear-gradient(135deg, #3a7bd5, #00d2ff); color: #fff;
            border-color: transparent; font-weight: 600; box-shadow: 0 4px 15px rgba(58,123,213,0.3);
        }
        .plat-icon { font-size: 1rem; }

        .search-section { margin-bottom: 12px; }
        .search-box { display: flex; gap: 8px; margin-bottom: 10px; }
        .search-box input {
            flex: 1; padding: 10px 16px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.15);
            background: rgba(255,255,255,0.06); color: #e0e0e0; font-size: 0.95rem;
            outline: none; transition: border-color 0.2s;
        }
        .search-box input:focus { border-color: #3a7bd5; }
        .search-box input::placeholder { color: #666; }
        #search-btn {
            padding: 10px 20px; border-radius: 10px; border: none;
            background: linear-gradient(135deg, #3a7bd5, #00d2ff); color: #fff;
            font-size: 0.9rem; cursor: pointer; font-weight: 600; transition: opacity 0.2s;
            white-space: nowrap;
        }
        #search-btn:hover { opacity: 0.85; }

        .hot-tags { display: flex; align-items: center; flex-wrap: wrap; gap: 6px; }
        .hot-label { font-size: 0.8rem; color: #666; margin-right: 4px; }
        .hot-tag {
            padding: 4px 12px; border-radius: 14px; border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.04); color: #aaa; font-size: 0.8rem;
            cursor: pointer; transition: all 0.2s;
        }
        .hot-tag:hover { background: rgba(255,255,255,0.1); color: #fff; }

        .current-filter {
            font-size: 0.85rem; color: #8e8ea0; padding-top: 12px;
            border-top: 1px solid rgba(255,255,255,0.06);
        }
        .cf-platform, .cf-keyword { color: #00d2ff; font-weight: 600; }
        .cf-date { color: #96ceb4; }
</style>
</head>
<body>
<div class="header">
    <h1>📊 数据看板</h1>
    <p>排行榜趋势 · 评论词云分析 · 自媒体内容灵感</p>
    <div class="header-date" id="header-date"></div>
</div>

<!-- 筛选控制区 -->
<div class="filter-bar">
    <div class="filter-section">
        <div class="filter-label">选择平台</div>
        <div class="platform-tabs" id="platform-tabs">
            <button class="platform-btn active" data-platform="bilibili"><span class="plat-icon">📺</span> B站</button>
            <button class="platform-btn" data-platform="douyin"><span class="plat-icon">🎵</span> 抖音</button>
            <button class="platform-btn" data-platform="xiaohongshu"><span class="plat-icon">📕</span> 小红书</button>
            <button class="platform-btn" data-platform="weibo"><span class="plat-icon">💭</span> 微博</button>
            <button class="platform-btn" data-platform="zhihu"><span class="plat-icon">💡</span> 知乎</button>
            <button class="platform-btn" data-platform="kuaishou"><span class="plat-icon">🎬</span> 快手</button>
            <button class="platform-btn" data-platform="wechat"><span class="plat-icon">💬</span> 公众号</button>
        </div>
    </div>
    <div class="search-section">
        <div class="filter-label">搜索垂类内容</div>
        <div class="search-box">
            <input type="text" id="search-input" placeholder="输入关键词搜索，如：美食、健身、科技..." />
            <button id="search-btn">🔍 搜索</button>
        </div>
        <div class="hot-tags">
            <span class="hot-label">热门垂类：</span>
            <button class="hot-tag" data-keyword="美食">美食</button>
            <button class="hot-tag" data-keyword="科技">科技</button>
            <button class="hot-tag" data-keyword="健身">健身</button>
            <button class="hot-tag" data-keyword="旅游">旅游</button>
            <button class="hot-tag" data-keyword="职场">职场</button>
            <button class="hot-tag" data-keyword="影视">影视</button>
            <button class="hot-tag" data-keyword="萌宠">萌宠</button>
            <button class="hot-tag" data-keyword="家居">家居</button>
        </div>
    </div>
    <div class="current-filter" id="current-filter">
        当前：<span class="cf-platform">B站</span> · <span class="cf-keyword">全部内容</span> · <span class="cf-date" id="filter-date"></span>
    </div>
</div>

<div class="dashboard">
    <!-- 排行榜模块 -->
    <div class="card">
        <div class="card-title"><span class="icon">🏆</span> 热门排行榜 <span class="list-count" id="ranking-count"></span></div>
        <div id="ranking-list" class="scroll-list"></div>
    </div>

    <!-- 词云模块 -->
    <div class="card">
        <div class="card-title"><span class="icon">💬</span> 评论区词云 <span id="wordcloud-source" style="font-size:0.75rem;color:#8e8ea0;font-weight:400;margin-left:8px;">点击排行榜内容查看对应词云</span></div>
        <div id="wordcloud-chart" style="width:100%;height:350px;"></div>
    </div>

    <!-- 24小时飙升榜 -->
    <div class="card">
        <div class="card-title"><span class="icon">⚡</span> 24小时热度飙升榜 <span class="list-count" id="rising24-count"></span></div>
        <div id="rising-24h-list" class="scroll-list"></div>
    </div>

    <!-- 72小时飙升榜 -->
    <div class="card">
        <div class="card-title"><span class="icon">🚀</span> 72小时热度飙升榜 <span class="list-count" id="rising72-count"></span></div>
        <div id="rising-72h-list" class="scroll-list"></div>
    </div>

    <!-- 自媒体内容建议 -->
    <div class="card full-width">
        <div class="card-title"><span class="icon">💡</span> 自媒体内容建议</div>
        <div id="content-suggestions"></div>
    </div>

    <!-- 趋势图表 -->
    <div class="card full-width">
        <div class="card-title"><span class="icon">📈</span> 热度趋势</div>
        <div id="trend-chart" style="width:100%;height:300px;"></div>
    </div>
</div>

<style>
    .rank-item {
        display: flex; align-items: center; padding: 12px 16px;
        border-radius: 10px; margin-bottom: 8px; transition: background 0.2s;
        background: rgba(255,255,255,0.03); cursor: pointer;
    }
    .rank-item:hover { background: rgba(255,255,255,0.08); }
    .rank-item.active { background: rgba(58,123,213,0.15); border: 1px solid rgba(58,123,213,0.3); }
    .rank-num {
        width: 28px; height: 28px; border-radius: 50%; display: flex;
        align-items: center; justify-content: center; font-weight: 700;
        font-size: 0.85rem; margin-right: 14px; flex-shrink: 0;
    }
    .rank-num.top1 { background: linear-gradient(135deg, #ffd700, #ffaa00); color: #333; }
    .rank-num.top2 { background: linear-gradient(135deg, #c0c0c0, #a0a0a0); color: #333; }
    .rank-num.top3 { background: linear-gradient(135deg, #cd7f32, #a0522d); color: #fff; }
    .rank-num.normal { background: rgba(255,255,255,0.1); color: #aaa; }
    .rank-info { flex: 1; }
    .rank-title { font-size: 0.95rem; font-weight: 500; margin-bottom: 3px; }
    .rank-meta { font-size: 0.8rem; color: #8e8ea0; }
    .rank-heat {
        font-size: 0.85rem; color: #ff6b6b; font-weight: 600;
        background: rgba(255,107,107,0.1); padding: 4px 10px; border-radius: 20px;
    }
    .suggestion-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 16px; }
    .suggestion-item {
        background: rgba(255,255,255,0.04); border-radius: 12px; padding: 18px;
        border-left: 3px solid; transition: transform 0.2s;

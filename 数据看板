function fillTemplate(template, vars) {
    return template.replace(/\{(\w+)\}/g, (match, key) => {
        const options = vars[key];
        if (!options) return match;
        return options[Math.floor(Math.random() * options.length)];
    });
}

function expandPlatformData(seedData, targetCount) {
    if (seedData.length >= targetCount) return seedData.slice(0, targetCount);
    const result = [...seedData];
    const categories = [...new Set(seedData.map(d => d.category))];
    const seenTitles = new Set(result.map(r => r.title));

    while (result.length < targetCount) {
        const cat = categories[Math.floor(Math.random() * categories.length)];
        const templates = expandTemplates.titles[cat];
        if (!templates) { categories.splice(categories.indexOf(cat), 1); if(categories.length===0) break; continue; }
        const template = templates[Math.floor(Math.random() * templates.length)];
        const title = fillTemplate(template, expandTemplates.vars);
        if (seenTitles.has(title)) continue;
        seenTitles.add(title);
        const authors = expandTemplates.authors[cat] || ["创作者"];
        const author = authors[Math.floor(Math.random() * authors.length)];
        result.push({ title, category: cat, author, heat: seedData[0].heat });
    }
    return result;
}

function expandRisingData(seedData, targetCount) {
    if (seedData.length >= targetCount) return seedData.slice(0, targetCount);
    const result = [...seedData];
    const categories = [...new Set(seedData.map(d => d.category))];
    const seenTitles = new Set(result.map(r => r.title));

    while (result.length < targetCount) {
        const cat = categories[Math.floor(Math.random() * categories.length)];
        const templates = expandTemplates.titles[cat];
        if (!templates) { categories.splice(categories.indexOf(cat), 1); if(categories.length===0) break; continue; }
        const template = templates[Math.floor(Math.random() * templates.length)];
        const title = fillTemplate(template, expandTemplates.vars);
        if (seenTitles.has(title)) continue;
        seenTitles.add(title);
        const authors = expandTemplates.authors[cat] || ["创作者"];
        const author = authors[Math.floor(Math.random() * authors.length)];
        const riseNum = Math.floor(Math.random() * 500) + 100;
        result.push({ title, category: cat, author, rise: `+${riseNum}%` });
    }
    return result;
}

// 为各平台数据自动分配合理的热度值
function assignHeatValues(data, platform) {
    const heatFormats = {
        bilibili: (i) => `${Math.max(352 - i * 3, 10)}万`,
        douyin: (i) => `${Math.max(890 - i * 8, 20)}万`,
        xiaohongshu: (i) => `${Math.max(45 - i * 0.4, 1).toFixed(1)}万`,
        weibo: (i) => i < 5 ? `${(4.2 - i * 0.4).toFixed(1)}亿` : `${Math.max(9800 - (i-5) * 90, 500)}万`,
        zhihu: (i) => `${Math.max(12000 - i * 100, 200)}回答`,
        kuaishou: (i) => `${Math.max(620 - i * 5, 15)}万`,
        wechat: (i) => i < 3 ? '10万+' : `${Math.max(9 - Math.floor(i * 0.08), 1)}万+`
    };
    const fmt = heatFormats[platform] || heatFormats.bilibili;
    return data.map((item, i) => ({ ...item, heat: i < (platformData[platform]||[]).length ? item.heat : fmt(i) }));
}

// 在初始化时扩展数据
function initExpandedData() {
    const TARGET = 100;
    for (const plat of Object.keys(platformData)) {
        platformData[plat] = assignHeatValues(expandPlatformData(platformData[plat], TARGET), plat);
        platformRising24h[plat] = expandRisingData(platformRising24h[plat], TARGET);
        platformRising72h[plat] = expandRisingData(platformRising72h[plat], TARGET);
        // 为72h榜增大涨幅
        platformRising72h[plat] = platformRising72h[plat].map((item, i) => {
            if (i >= 8) { // 保留种子数据原始值
                const num = Math.floor(Math.random() * 2000) + 500;
                return { ...item, rise: `+${num}%` };
            }
            return item;
        });
    }
}



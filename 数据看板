        background: rgba(0,210,255,0.1); color: #00d2ff; border: 1px solid rgba(0,210,255,0.2);
        cursor: pointer; transition: all 0.2s;
    }
    .kw-item:hover { background: rgba(0,210,255,0.2); }
    /* 大纲样式 */
    .sug-outline {
        margin-top: 10px; padding: 10px 12px; border-radius: 8px;
        background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);
    }
    .outline-label {
        font-size: 0.72rem; color: #96ceb4; font-weight: 600; margin-bottom: 6px;
    }
    .outline-content {
        font-size: 0.78rem; color: #bbb; line-height: 1.7;
    }
    /* 爆款标题样式 */
    .sug-titles {
        margin-top: 10px; padding: 10px 12px; border-radius: 8px;
        background: rgba(254,202,87,0.04); border: 1px solid rgba(254,202,87,0.12);
    }
    .titles-label {
        font-size: 0.72rem; color: #feca57; font-weight: 600; margin-bottom: 6px;
    }
    .title-option {
        font-size: 0.82rem; color: #e0e0e0; padding: 4px 0; line-height: 1.6;
        border-bottom: 1px dashed rgba(255,255,255,0.05);
    }
    .title-option:last-child { border-bottom: none; }
    /* 飙升榜样式 */
    .rising-item {
        display: flex; align-items: center; padding: 10px 14px;

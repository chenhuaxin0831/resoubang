function generateTitleSuggestions(category, keyword) {
    const templates = titleFormulas[category] || titleFormulas["生活"];
    const kw = keyword || "内容";
    // 随机选3条不重复的
    const shuffled = [...templates].sort(() => Math.random() - 0.5);
    return shuffled.slice(0, 3).map(t => t.replace(/\{keyword\}/g, kw));
}


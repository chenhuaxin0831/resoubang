    .rising-meta { font-size: 0.75rem; color: #8e8ea0; margin-top: 2px; }
    .rising-badge {
        font-size: 0.8rem; font-weight: 700; padding: 3px 10px; border-radius: 14px;
        white-space: nowrap; flex-shrink: 0; margin-left: 8px;
    }
    .rising-badge.up {

        transition: background 0.2s; cursor: pointer;
    }
    .rising-item:hover { background: rgba(255,255,255,0.08); }
    .rising-item.active { background: rgba(58,123,213,0.15); border: 1px solid rgba(58,123,213,0.3); }
    .rising-rank {
